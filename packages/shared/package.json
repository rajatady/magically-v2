{
  "name": "@magically/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/types.js",
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./api-client": {
      "types": "./dist/api-client.d.ts",
      "default": "./dist/api-client.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    },
    "./dockerfile": {
      "types": "./dist/dockerfile.d.ts",
      "default": "./dist/dockerfile.js"
    },
    "./harness": {
      "types": "./dist/harness.d.ts",
      "default": "./dist/harness.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "rxjs": "^7.8.2",
    "zod": "^3.24.1"
  }
}
