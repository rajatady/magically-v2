# Database (local Postgres for dev, Neon for prod)
DATABASE_URL=postgres://localhost:5432/magically_v2

FLY_API_TOKEN=Fly_token
FLY_AGENTS_APP=magically-v2
FLY_SPRITE_API_TOKEN=fly_sprites_api_token
DAYTONA_API_KEY=dtn_...

# Compute provider for container agents: fly | docker | auto (default: auto)
COMPUTE_PROVIDER=auto

VERCEL_API_TOKEN=vercel_api_token

JWT_SECRET=$(openssl rand -base64 32)
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret

# Runtime URL (for OAuth callbacks)
RUNTIME_URL=http://localhost:4321

# Web URL (for CORS + OAuth redirect)
WEB_URL=http://localhost:5173

# Redis (BullMQ job queue — `docker compose up redis` for local, Upstash for prod)
REDIS_URL=redis://localhost:6379

# GHCR (where container agent images are stored)
GHCR_REGISTRY=ghcr.io/your-username/magically-agents

# GitHub Actions builder (triggers remote Docker builds — no local Docker needed)
# Token needs `actions` scope. Repo contains the build workflow.
GITHUB_BUILDER_REPO=your-username/magically-builders
GITHUB_BUILDER_TOKEN=ghp_your_github_token

# Tigris storage (S3-compatible — agent bundles)
AWS_REGION=auto
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_ACCESS_KEY_ID=your_tigris_access_key
AWS_SECRET_ACCESS_KEY=your_tigris_secret_key
BUCKET_NAME=magically-registry