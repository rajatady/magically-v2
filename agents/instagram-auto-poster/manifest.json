{
  "id": "instagram-auto-poster",
  "name": "Instagram Auto Poster",
  "version": "1.0.4",
  "description": "Autonomous Instagram content engine — generates, renders, publishes, and tracks carousels and reels on a schedule",
  "icon": "📸",
  "color": "#E1306C",
  "author": "kumar",
  "category": "social",
  "tags": ["instagram", "social-media", "content", "automation"],

  "secrets": [
    "IG_CT_ACCESS_TOKEN",
    "IG_CT_ACCOUNT_ID",
    "BLOB_READ_WRITE_TOKEN"
  ],

  "config": {
    "accountHandle": { "type": "string", "label": "Instagram handle", "required": true },
    "postingFrequency": { "type": "string", "label": "Hours between posts", "default": "4" },
    "contentNiche": { "type": "string", "label": "What kind of content?", "required": true },
    "targetAudience": { "type": "string", "label": "Who is your audience?" },
    "languages": { "type": "array", "label": "Programming languages to cover", "default": ["javascript", "python"] },
    "autoPublish": { "type": "boolean", "label": "Publish without approval", "default": false },
    "postsPerCycle": { "type": "number", "label": "Posts per growth cycle", "default": 4 }
  },

  "runtime": {
    "base": "python:3.12-slim",
    "system": ["chromium", "fonts-noto-cjk", "fonts-noto", "nodejs", "npm"],
    "install": "pip install playwright Pillow requests python-dotenv && playwright install chromium --with-deps"
  },

  "triggers": [
    {
      "type": "cron",
      "name": "Growth Cycle",
      "entrypoint": "growthCycle",
      "schedule": "17 */4 * * *"
    },
    {
      "type": "cron",
      "name": "Refresh Analytics",
      "entrypoint": "fetchInsights",
      "schedule": "0 */6 * * *"
    }
  ],

  "functions": [
    {
      "name": "growthCycle",
      "description": "Full autonomous cycle: analyze → plan → create → render → publish → track",
      "parameters": { "type": "object", "properties": { "count": { "type": "number" } } },
      "run": "node functions/growthCycle.js"
    },
    {
      "name": "fetchInsights",
      "description": "Fetch latest Instagram analytics and save snapshot",
      "parameters": {},
      "run": "python insights.py"
    },
    {
      "name": "publish",
      "description": "Publish a rendered carousel to Instagram",
      "parameters": { "type": "object", "properties": { "contentPath": { "type": "string" } }, "required": ["contentPath"] },
      "run": "python publish_carousel.py"
    }
  ]
}
