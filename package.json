{
  "name": "magically",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source personal Agent OS",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "magically": "npx ts-node packages/cli/src/index.ts",
    "db:generate": "cd packages/runtime && bun run db:generate",
    "db:migrate": "cd packages/runtime && bun run db:migrate",
    "db:push": "cd packages/runtime && bun run db:push",
    "db:studio": "cd packages/runtime && bun run db:studio",
    "desktop": "cd packages/shared && bun run build && cd ../../apps/web && VITE_API_URL=http://localhost:4321 npx vite build --base './' && rm -rf ../desktop/web-dist && cp -r dist ../desktop/web-dist && cd ../desktop && npx electron .",
    "desktop:dev": "cd apps/desktop && npx electron ."
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.2.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "trustedDependencies": [
    "@nestjs/core",
    "electron"
  ],
  "overrides": {
    "yallist": "4.0.0"
  },
  "dependencies": {
    "@nestjs/passport": "^11.0.5",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1"
  }
}
