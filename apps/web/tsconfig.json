{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["vite/client"],
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@magically/agent-sdk": ["../../packages/agent-sdk/src/index.ts"],
      "@magically/widget-dsl": ["../../packages/widget-dsl/src/index.ts"]
    }
  },
  "include": ["src"]
}
