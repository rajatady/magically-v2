{
  "name": "@magically/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:web": "cd ../web && bun run build",
    "package": "electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "devDependencies": {
    "electron": "33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.magically.desktop",
    "productName": "Magically",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": ["dmg"]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "web-dist/**/*",
      "assets/**/*"
    ]
  }
}
