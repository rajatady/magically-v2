{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "incremental": true,
    "tsBuildInfoFile": "./.buildcache/tsconfig.tsbuildinfo"
  },
  "include": ["packages/*/src", "agents/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
