#!/bin/bash

# Pre-commit hook: ensure docs are updated when source changes.
#
# Monorepo paths: packages/*, apps/*, drizzle/, Dockerfile, fly.toml, .github/
# If any of these are staged, at least one file in README.md, CHANGELOG.md,
# or docs/current/ must also be staged.
# Skip with: git commit --no-verify

STAGED=$(git diff --cached --name-only)

# Source file patterns (monorepo)
SOURCE_PATTERN='^(packages/|apps/|drizzle/|Dockerfile|fly\.toml|\.github/)'

# Check if any source files are staged
HAS_SOURCE=$(echo "$STAGED" | grep -E "$SOURCE_PATTERN" | head -1)

if [ -z "$HAS_SOURCE" ]; then
  exit 0  # No source changes, docs not required
fi

# Check if any docs are staged
HAS_DOCS=$(echo "$STAGED" | grep -E '^(README\.md|CHANGELOG\.md|docs/)' | head -1)

if [ -z "$HAS_DOCS" ]; then
  echo ""
  echo "  COMMIT BLOCKED: source files changed but no docs updated."
  echo ""
  echo "  Staged source files:"
  echo "$STAGED" | grep -E "$SOURCE_PATTERN" | sed 's/^/    /'
  echo ""
  echo "  Update at least one of:"
  echo "    - README.md"
  echo "    - CHANGELOG.md"
  echo "    - docs/current/*.md"
  echo ""
  echo "  Or skip with: git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
